[
  {
    "name": "document byte limit",
    "input": "secret = \"value\"",
    "limits": {
      "maxDocumentBytes": 8
    },
    "expected": {
      "code": "acl.limit.document_bytes",
      "message": "ACL parse limit exceeded: document is larger than 8 bytes",
      "span": {
        "start": { "line": 1, "column": 1, "offset": 0 },
        "end": { "line": 1, "column": 1, "offset": 0 }
      }
    }
  },
  {
    "name": "UTF-8 token byte limit",
    "input": "name = \"智谱\"",
    "limits": {
      "maxTokenBytes": 7
    },
    "expected": {
      "code": "acl.limit.token_bytes",
      "message": "ACL parse limit exceeded: token is longer than 7 bytes",
      "span": {
        "start": { "line": 1, "column": 8, "offset": 7 },
        "end": { "line": 1, "column": 12, "offset": 15 }
      }
    }
  },
  {
    "name": "nesting depth limit",
    "input": "root { child { value = true } }",
    "limits": {
      "maxNestingDepth": 1
    },
    "expected": {
      "code": "acl.limit.nesting_depth",
      "message": "ACL parse limit exceeded: nesting depth is greater than 1",
      "span": {
        "start": { "line": 1, "column": 14, "offset": 13 },
        "end": { "line": 1, "column": 15, "offset": 14 }
      }
    }
  },
  {
    "name": "collection item limit",
    "input": "first = 1\nsecond = 2",
    "limits": {
      "maxCollectionItems": 1
    },
    "expected": {
      "code": "acl.limit.collection_items",
      "message": "ACL parse limit exceeded: collection has more than 1 items",
      "span": {
        "start": { "line": 2, "column": 1, "offset": 10 },
        "end": { "line": 2, "column": 7, "offset": 16 }
      }
    }
  },
  {
    "name": "unexpected string redacts its value",
    "input": "\"TOP_SECRET\"",
    "limits": {},
    "expected": {
      "code": "acl.parse.unexpected_token",
      "message": "Unexpected token: String",
      "span": {
        "start": { "line": 1, "column": 1, "offset": 0 },
        "end": { "line": 1, "column": 13, "offset": 12 }
      }
    }
  },
  {
    "name": "UTF-8 offsets remain byte based",
    "input": "name = \"智谱\"\n]",
    "limits": {},
    "expected": {
      "code": "acl.parse.unexpected_token",
      "message": "Unexpected token: RightBracket",
      "span": {
        "start": { "line": 2, "column": 1, "offset": 16 },
        "end": { "line": 2, "column": 2, "offset": 17 }
      }
    }
  },
  {
    "name": "expected call delimiter",
    "input": "value = env(\"TOP_SECRET\" true)",
    "limits": {},
    "expected": {
      "code": "acl.parse.expected_token",
      "message": "Expected ',' or ')', found True",
      "span": {
        "start": { "line": 1, "column": 26, "offset": 25 },
        "end": { "line": 1, "column": 30, "offset": 29 }
      }
    }
  },
  {
    "name": "unexpected value token",
    "input": "password = ]",
    "limits": {},
    "expected": {
      "code": "acl.parse.unexpected_token",
      "message": "Unexpected token in value position: RightBracket",
      "span": {
        "start": { "line": 1, "column": 12, "offset": 11 },
        "end": { "line": 1, "column": 13, "offset": 12 }
      }
    }
  },
  {
    "name": "unexpected end of input",
    "input": "value = env(",
    "limits": {},
    "expected": {
      "code": "acl.parse.unexpected_eof",
      "message": "Unexpected end of input",
      "span": {
        "start": { "line": 1, "column": 13, "offset": 12 },
        "end": { "line": 1, "column": 13, "offset": 12 }
      }
    }
  }
]
